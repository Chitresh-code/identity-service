PORT=8080
DATABASE_URL=postgres://user:password@localhost:5432/identity?sslmode=disable
# "local" (default) gets human-readable request logs; anything else gets JSON.
ENVIRONMENT=local
# Auth0 Regular Web Application -- Settings tab of the app in the Auth0 dashboard.
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
# Used to build the OAuth callback URL (/auth/callback) and the post-logout
# redirect. Must match an Allowed Callback URL / Allowed Logout URL in Auth0.
APP_BASE_URL=http://localhost:8080
# Relying-party frontends allowed to receive a post-login handoff code via
# /auth/login?redirect_uri=... . Comma separated, exact match. Not an Auth0
# setting -- Auth0 only ever redirects back to APP_BASE_URL/auth/callback
# above; this is identity-service's own second-hop allowlist.
AUTH_ALLOWED_REDIRECT_URIS=http://localhost:3100/auth/callback
